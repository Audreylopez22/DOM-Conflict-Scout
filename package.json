{
  "name": "@audreylopez/dom-conflict-scout",
  "version": "1.0.5",
  "description": "A lightweight library to detect DOM injections from browser extensions.",
  "main": "./dist/detector.cjs",
  "module": "./dist/detector.js",
  "types": "./dist/detector.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/detector.d.ts",
      "import": "./dist/detector.js",
      "require": "./dist/detector.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/detector.ts --format esm,cjs,iife --global-name DOMConflictScout --dts --minify --clean",
    "dev": "pnpm run build -- --watch",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "browser",
    "dom",
    "conflict",
    "extension",
    "auditor",
    "detector"
  ],
  "author": "Audrey Lopez",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Audreylopez22/DOM-Conflict-Scout.git"
  },
  "bugs": {
    "url": "https://github.com/Audreylopez22/DOM-Conflict-Scout/issues"
  },
  "homepage": "https://github.com/Audreylopez22/DOM-Conflict-Scout#readme",
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.6.2",
    "esbuild": "^0.28.0",
    "tsup": "^8.0.2",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
