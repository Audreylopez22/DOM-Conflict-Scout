{
  "name": "@audreylopez/dom-conflict-scout",
  "version": "1.0.0",
  "description": "A browser extension for auditing web pages.",
  "main": "./dist/detector.js",
  "module": "./dist/detector.mjs",
  "types": "./dist/detector.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/detector.ts --format esm,cjs --dts --minify --clean",
    "dev": "pnpm run build -- --watch",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "browser",
    "extension",
    "auditor"
  ],
  "author": "Audrey Lopez",
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Audreylopez22/DOM-Conflict-Scout.git"
  },
  "bugs": {
    "url": "https://github.com/Audreylopez22/DOM-Conflict-Scout/issues"
  },
  "homepage": "https://github.com/Audreylopez22/DOM-Conflict-Scout#readme",
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/node": "^20.12.12",
    "esbuild": "^0.21.3",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
